# Mailchimp (server-side, optional)
# When set, /api/subscribe will POST members to Mailchimp with tags.
# When unset, the route logs to console (stub mode for local dev / pre-launch).
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_DC=us2

# Amplitude (client-side, optional)
# When set, the analytics wrapper sends events to Amplitude.
# When unset, all track() calls are no-ops.
NEXT_PUBLIC_AMPLITUDE_API_KEY=
