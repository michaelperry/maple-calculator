# Mailchimp (server-side, optional)
# When set, /api/subscribe will POST members to Mailchimp with tags.
# When unset, the route logs to console (stub mode for local dev / pre-launch).
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_DC=us2

# Amplitude (client-side, optional)
# When set, the analytics wrapper sends events to Amplitude.
# When unset, all track() calls are no-ops.
NEXT_PUBLIC_AMPLITUDE_API_KEY=

# Upstash Redis (server-side, optional)
# Provision via Vercel Marketplace → Upstash Redis. Both vars are
# auto-injected by the integration. When set, the following features
# activate on the next deploy:
#   - Short-ID share URLs  (/r/<id>)  — server-persisted, pretty in iMessage
#   - Social-proof counter on the landing page  — real-time completion count
# When unset, short URLs fall back to base64 ?r=... and the counter shows a baseline.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Canonical site URL (optional)
# Used as metadataBase when building absolute OG image URLs. Falls back to
# VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL / localhost when unset. Set this
# to your custom domain once you hook one up (e.g. https://growmaple.com).
NEXT_PUBLIC_SITE_URL=
